# Environment variables for AI Traffic Optimizer
# Copy this file to .env and fill in values before running server.js

# Node.js server port
PORT=4000

# ZeroMQ address of the optimizer.py PUB socket
ZMQ_SUB_ADDR=tcp://127.0.0.1:5556

# JWT secret — CHANGE THIS in production
JWT_SECRET=replace_with_a_long_random_secret_string

# JWT token expiry
JWT_EXPIRES_IN=8h

# Number of lanes monitored
N_LANES=4

# React frontend origin (for CORS)
CORS_ORIGIN=http://localhost:3000
